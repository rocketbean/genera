{
  "name": "@rocketbean/genera",
  "version": "0.0.0",
  "description": "One API for every cloud storage provider. A driver-based, provider-agnostic, isomorphic storage layer for TypeScript.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./node": {
      "import": {
        "types": "./dist/node.d.ts",
        "default": "./dist/node.js"
      },
      "require": {
        "types": "./dist/node.d.cts",
        "default": "./dist/node.cjs"
      }
    },
    "./conformance": {
      "import": {
        "types": "./dist/conformance.d.ts",
        "default": "./dist/conformance.js"
      },
      "require": {
        "types": "./dist/conformance.d.cts",
        "default": "./dist/conformance.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --project node",
    "test:browser": "vitest run --project browser",
    "test:watch": "vitest --project node"
  },
  "keywords": [
    "storage",
    "cloud",
    "s3",
    "abstraction",
    "driver",
    "isomorphic",
    "filesystem",
    "provider-agnostic"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vitest": "^4"
  },
  "peerDependenciesMeta": {
    "vitest": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
