{
  "name": "@rocketbean/genera-dropbox",
  "version": "0.0.0",
  "description": "Dropbox storage driver for Genera (isomorphic — Node + browser).",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "keywords": [
    "storage",
    "dropbox",
    "genera",
    "driver"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@rocketbean/genera": "workspace:^",
    "dropbox": "^10"
  },
  "devDependencies": {
    "@rocketbean/genera": "workspace:*",
    "@types/node": "^22",
    "dropbox": "^10",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
