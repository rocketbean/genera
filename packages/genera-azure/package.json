{
  "name": "@rocketbean/genera-azure",
  "version": "1.0.0",
  "description": "Azure Blob Storage driver for Genera (isomorphic — Node + browser).",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "tsc --noEmit && tsup"
  },
  "keywords": [
    "storage",
    "azure",
    "azure-blob",
    "blob-storage",
    "genera",
    "driver"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@azure/storage-blob": "^12",
    "@rocketbean/genera": "workspace:^"
  },
  "devDependencies": {
    "@azure/storage-blob": "^12",
    "@rocketbean/genera": "workspace:*",
    "@types/node": "^22",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
