{
  "name": "genera-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Monorepo for @rocketbean/genera — one API for every cloud storage provider.",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "lint": "eslint packages",
    "format": "prettier --write \"packages/**/*.{ts,json}\"",
    "format:check": "prettier --check \"packages/**/*.{ts,json}\"",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "ci": "pnpm lint && pnpm typecheck && pnpm build && pnpm test",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm -r build && changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2",
    "@eslint/js": "^9",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "playwright": "^1.61.0",
    "prettier": "^3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8"
  }
}
